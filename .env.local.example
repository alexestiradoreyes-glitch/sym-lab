# ============================================================
# SYM LAB — Variables de entorno
# Copia este archivo como .env.local y rellena tus valores
# ============================================================

# --- CORREO (Outlook / Microsoft 365) ---
# Para cuentas personales de Outlook usar: smtp-mail.outlook.com
# Para cuentas de empresa Microsoft 365 usar: smtp.office365.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=tucorreo@empresa.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion

# Correo donde se recibirán las ideas (puede ser el mismo u otro)
EMAIL_DESTINO=aestirado@sym-naval.com

# --- EXCEL ---
# Ruta donde se guardará el archivo Excel con las ideas.
# Por defecto: carpeta "data" dentro del proyecto (data/ideas.xlsx)
# Puedes usar una ruta absoluta: C:/Documentos/sym-lab/ideas.xlsx
EXCEL_PATH=

# Carpeta donde se guardarán los archivos adjuntos de cada idea
# Por defecto: carpeta "uploads" dentro del proyecto
UPLOADS_DIR=

# --- PANEL DE ADMINISTRACIÓN ---
# Contraseña para acceder al panel de administración
ADMIN_PASSWORD=Estimaco_03


# Token de sesión (genera uno aleatorio, mínimo 32 caracteres)
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET_TOKEN=genera_un_token_aleatorio_aqui_32_caracteres_minimo

# --- ENTORNO ---
NODE_ENV=development
